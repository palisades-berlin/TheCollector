# THE Collector does not require runtime environment variables.
# This file is intentionally minimal and reserved for future local tooling.

# Optional local QA/perf script variables
# These are only used by scripts in `scripts/` and are not used by extension
# runtime code in `src/`. They tune local validation behavior only.

# scripts/perf-popup-budget.mjs
# Number of measured popup runs for p95 calculation.
PERF_RUNS=7
# Number of warm-up runs ignored before measurement.
PERF_WARMUP_RUNS=1
# Popup p95 interactive budget in milliseconds.
POPUP_P95_BUDGET_MS=150
# Release zip package-size budget in bytes.
PACKAGE_BUDGET_BYTES=400000

# scripts/smoke-soak.mjs
# Number of smoke iterations to execute.
SOAK_ITERATIONS=5
